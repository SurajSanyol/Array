class Solution {
public:
    vector<int> prevPermOpt1(vector<int>&nums) {
        int index = -1;

        for (int i = nums.size() - 2; i >= 0; i--) {
            if (nums[i] > nums[i + 1]) {
                index = i;
                break;
            }
        }

         if (index == -1) {

            return nums;
        }

        for (int i = nums.size() - 1; i > index; i--) {
            if (nums[i] < nums[index] && nums[i]!=nums[i-1]) {
                swap(nums[i], nums[index]);
                break;
            }
        }

        return nums;
    }
};
